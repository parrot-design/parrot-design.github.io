{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name":"node调试vue2 build",
            "request":"launch",
            "runtimeArgs": [
                "run-script",
                "build"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "localRoot": "${workspaceFolder}/vue2",
        },
        {
            "name":"node调试vue2 dev",
            "request":"launch",
            "runtimeArgs": [
                "run-script",
                "dev"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "localRoot": "${workspaceFolder}/vue2",
        },
        {
            "name":"网页调试angular",
            "request":"launch",
            "type":"chrome",
            "url":"http://localhost:4200",
            "webRoot": "${workspaceFolder}/angular-demo"
        }
    ]
}